{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "knit-together.vercel.app" }],
      "destination": "https://knit.gatheredin.app/",
      "permanent": true
    },
    {
      "source": "/((?!api/).*)",
      "has": [{ "type": "host", "value": "knit-together.vercel.app" }],
      "destination": "https://knit.gatheredin.app/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/((?!api/|.*\\.).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/cron/*.ts": { "maxDuration": 300 },
    "api/admin/sheet.ts": { "maxDuration": 120 }
  },
  "crons": [
    { "path": "/api/cron/sheets-morning-push", "schedule": "0 12 * * *" },
    { "path": "/api/cron/availability-refresh", "schedule": "0 16 * * *" }
  ]
}
